# XYGo 后端开发自动化脚本

.PHONY: help
help:
	@echo "XYGo 后端开发命令："
	@echo ""
	@echo "  make dao             生成 DAO 层代码（gf gen dao）"
	@echo "  make service         生成 Service 层代码（gf gen service）"
	@echo "  make logic-import    自动生成 logic.go 导入语句"
	@echo "  make gen             一键生成全部（dao + logic-import + service）"
	@echo "  make build           编译项目"
	@echo "  make run             热编译运行"
	@echo "  make clean           清理备份文件"
	@echo ""

# 生成 DAO 层
.PHONY: dao
dao:
	gf gen dao

# 生成 Service 层
.PHONY: service
service:
	gf gen service

# 自动生成 logic.go（扫描 internal/logic 目录）
.PHONY: logic-import
logic-import:
	@echo "// ==========================================================================" > internal/logic/logic.go
	@echo "// Code generated by Makefile. DO NOT EDIT manually." >> internal/logic/logic.go
	@echo "// Run 'make logic-import' to regenerate this file." >> internal/logic/logic.go
	@echo "// ==========================================================================" >> internal/logic/logic.go
	@echo "" >> internal/logic/logic.go
	@echo "package logic" >> internal/logic/logic.go
	@echo "" >> internal/logic/logic.go
	@echo "import (" >> internal/logic/logic.go
	@powershell -Command "Get-ChildItem -Path internal/logic -Directory | ForEach-Object { Write-Output ('	_ \"xygo/internal/logic/' + $$_.Name + '\"') }" >> internal/logic/logic.go
	@echo ")" >> internal/logic/logic.go
	@echo "✅ logic.go 已自动生成"

# 一键生成全部
.PHONY: gen
gen:
	@echo "========== 开始生成代码 =========="
	@echo ""
	@echo "步骤1/3: 生成 DAO 层..."
	@make dao
	@echo ""
	@echo "步骤2/3: 生成 logic.go 导入语句..."
	@make logic-import
	@echo ""
	@echo "步骤3/3: 生成 Service 层..."
	@make service
	@echo ""
	@echo "========== 代码生成完成 =========="

# 编译项目
.PHONY: build
build:
	go build -o xygo.exe .

# 热编译运行
.PHONY: run
run:
	gf run main.go

# 清理备份文件
.PHONY: clean
clean:
	@powershell -Command "Remove-Item -Path internal/service/*.bak -ErrorAction SilentlyContinue"
	@echo "✅ 备份文件已清理"
